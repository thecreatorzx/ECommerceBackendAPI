<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>E-Commerce API Tester</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        pre { background: #282c34; color: #abb2bf; padding: 15px; border-radius: 8px; max-height: 400px; overflow-y: auto; }
        .method-select { width: 110px; font-weight: bold; }
        .card { border: none; border-radius: 12px; }
        .sticky-top { top: 20px; }
    </style>
</head>
<body class="bg-light">

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>🛒 Backend API Dashboard</h1>
        <button onclick="location.reload()" class="btn btn-primary">🔄 Sync Inventory</button>
    </div>

    <div class="row">
        <div class="col-lg-6">
            <div class="card shadow-sm mb-4 sticky-top">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <span>🚀 Mini Postman</span>
                    <select id="quickFill" class="form-select form-select-sm w-50" onchange="applyQuickFill()">
                        <option value="">-- Quick Load Endpoint --</option>
                        <option value="getProducts">GET All Products</option>
                        <option value="searchProducts">SEARCH Products (iPhone)</option>
                        <option value="updatePrice">PATCH Update Price</option>
                        <option value="getCart">GET Cart Items</option>
                        <option value="addToCart">POST Add to Cart</option>
                        <option value="createOrder">POST Place Order</option>
                    </select>
                </div>
                <div class="card-body">
                    <div class="input-group mb-3">
                        <select id="method" class="form-select method-select bg-light">
                            <option value="GET">GET</option>
                            <option value="POST">POST</option>
                            <option value="PATCH">PATCH</option>
                            <option value="DELETE">DELETE</option>
                        </select>
                        <input type="text" id="url" class="form-control" placeholder="/products" value="/products">
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Request Body (JSON):</label>
                        <textarea id="body" class="form-control font-monospace" rows="6">{}</textarea>
                    </div>

                    <button onclick="sendRequest()" class="btn btn-success w-100 py-2 fw-bold">SEND REQUEST</button>
                    
                    <div class="mt-4">
                        <label class="form-label fw-bold">📡 Server Response:</label>
                        <pre id="response">No request sent yet...</pre>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white fw-bold">📊 Current Product Inventory</div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Name</th>
                                    <th>Price</th>
                                    <th>Stock</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% products.forEach(p => { %>
                                    <tr>
                                        <td><code>#<%= p.id %></code></td>
                                        <td class="fw-bold"><%= p.name %></td>
                                        <td class="text-success">₹<%= p.price %></td>
                                        <td>
                                            <span class="badge <%= p.stock > 0 ? 'bg-info' : 'bg-danger' %>">
                                                <%= p.stock %> in stock
                                            </span>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const presets = {
        getProducts: { method: 'GET', url: '/products', body: {} },
        searchProducts: { method: 'GET', url: '/products/search?q=iPhone', body: {} },
        updatePrice: { method: 'PATCH', url: '/products/price', body: { id: 1, price: 85000 } },
        getCart: { method: 'GET', url: '/cart', body: {} },
        addToCart: { method: 'POST', url: '/cart', body: { productId: 1, quantity: 1 } },
        createOrder: { method: 'POST', url: '/orders', body: { items: [{ productId: 1, quantity: 1 }] } }
    };

    function applyQuickFill() {
        const val = document.getElementById('quickFill').value;
        if (presets[val]) {
            document.getElementById('method').value = presets[val].method;
            document.getElementById('url').value = presets[val].url;
            document.getElementById('body').value = JSON.stringify(presets[val].body, null, 2);
        }
    }

    async function sendRequest() {
        const method = document.getElementById('method').value;
        const url = document.getElementById('url').value;
        const bodyInput = document.getElementById('body').value;
        const respBox = document.getElementById('response');

        respBox.innerText = "⏳ Processing...";

        const options = {
            method: method,
            headers: { 'Content-Type': 'application/json' }
        };

        if (method !== 'GET' && method !== 'DELETE') {
            try {
                options.body = JSON.stringify(JSON.parse(bodyInput));
            } catch (e) {
                respBox.innerText = "❌ Error: Invalid JSON in Body field.";
                return;
            }
        }

        try {
            const res = await fetch(url, options);
            const contentType = res.headers.get("content-type");
            
            if (contentType && contentType.includes("application/json")) {
                const data = await res.json();
                respBox.innerText = JSON.stringify(data, null, 2);
            } else {
                const text = await res.text();
                respBox.innerText = "⚠️ Received HTML/Text (Check URL):\n\n" + text.substring(0, 200);
            }
        } catch (err) {
            respBox.innerText = "❌ Fetch Error: " + err.message;
        }
    }
</script>
</body>
</html>